# ============================================
# Docker Ignore File
# Prevents unnecessary files from being copied to Docker context
# ============================================

# Git
.git
.gitignore
.gitattributes

# Node.js
egg
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Build outputs
dist
build
.nyc_output
coverage

# Environment files
.env
.env.local
.env.*.local
!.env.example
!.env.docker

# IDE
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Docker files themselves (not needed in context)
Dockerfile*
docker-compose*.yml
docker-compose*.yaml
.dockerignore

# Documentation (not needed for build)
*.md
!README.md

docker-start.*

# Test files
test
tests
__tests__
*.test.js
*.spec.js

# CI/CD
.github
.gitlab-ci.yml
.travis.yml

# Misc
*.log
.cache
temp
tmp
*.tmp
