# ============================================
# AVATAR CHATBOT - FRONTEND ENVIRONMENT
# ============================================

# API URL Configuration
# For local development: http://localhost:3001
# For Render deployment: https://your-api.onrender.com
# No trailing slash
VITE_API_URL=http://localhost:3001

# Production API URL (used in production builds)
# Set this to your deployed backend URL
VITE_PROD_API_URL=https://your-api.onrender.com

# Feature flags
VITE_ENABLE_SPEECH=true
VITE_ENABLE_STREAMING=true
VITE_ENABLE_EMOTIONS=true
