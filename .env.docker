# ============================================
# AI Healthcare Avatar Platform
# Docker Environment Configuration
# ============================================
# Copy this file to .env and customize for your setup
# NEVER commit .env to version control!
# ============================================

# ============================================
# NETWORK CONFIGURATION
# ============================================

# Frontend port (access the UI here)
FRONTEND_PORT=80

# Backend API port
BACKEND_PORT=3001

# MongoDB port (host mapping)
MONGODB_PORT=27017

# Ollama port (if using Ollama container)
OLLAMA_PORT=11434

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API URL for frontend to connect to backend
# In Docker: use the service name or localhost if exposing ports
VITE_API_URL=http://localhost:3001
VITE_PROD_API_URL=http://localhost:3001

# Feature flags
VITE_ENABLE_SPEECH=true
VITE_ENABLE_STREAMING=true
VITE_ENABLE_EMOTIONS=true

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Node environment
NODE_ENV=production

# Server port (inside container)
PORT=3001

# MongoDB Connection
# Option 1: Use Docker MongoDB container
MONGODB_URI=mongodb://mongodb:27017/avatar_db

# Option 2: Use MongoDB Atlas (uncomment and configure)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/avatar_db?retryWrites=true&w=majority

# JWT Secret (generate strong random string for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# OLLAMA CONFIGURATION
# ============================================

# OLLAMA_URL options:
# 1. Local Ollama on host machine (recommended for hackathons):
#    For Windows/Mac: http://host.docker.internal:11434
#    For Linux: http://172.17.0.1:11434 (host IP may vary)
#
# 2. Ollama in Docker container (uncomment in docker-compose.yml):
#    http://ollama:11434
#
# 3. Remote Ollama server:
#    http://your-server-ip:11434

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# ============================================
# CORS CONFIGURATION
# ============================================

# Allowed origins (comma-separated)
ALLOWED_ORIGIN=http://localhost,http://localhost:80
FRONTEND_URL=http://localhost:80

# ============================================
# CLOUD AI PROVIDERS (Optional Fallbacks)
# ============================================
# These are used when Ollama is unavailable
# Leave empty if not using cloud providers

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ============================================
# HACKATHON QUICK START
# ============================================
#
# 1. Install Ollama on your host machine:
#    https://ollama.com/download
#
# 2. Pull phi3 model:
#    ollama pull phi3
#
# 3. Start Ollama (keep running):
#    ollama serve
#
# 4. Copy this file:
#    cp .env.docker .env
#
# 5. Start the platform:
#    docker compose up -d
#
# 6. Access the app:
#    http://localhost
#
# 7. Verify Ollama connection:
#    curl http://localhost:3001/api/health/ollama
#
# ============================================
