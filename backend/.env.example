# ============================================
# AVATAR CHATBOT - BACKEND ENVIRONMENT
# ============================================

# MongoDB Atlas Connection
# Get from: https://www.mongodb.com/cloud/atlas
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/avatar_db?retryWrites=true&w=majority

# JWT Secret for authentication
# Generate a strong random string: https://jwtsecret.com/generate
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Anthropic Claude API (optional fallback)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# Ollama Configuration (primary AI)
# For local development: http://localhost:11434
# For ngrok tunnel: https://your-ngrok-url.ngrok.io
# For remote Ollama: http://your-remote-server:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# Cloud API Keys (optional - used as fallbacks if Ollama unavailable)
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# CORS Configuration
# Comma-separated list of allowed origins
# For Vercel deployment: https://your-app.vercel.app
ALLOWED_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Server port (Render uses 10000, local uses 3001)
PORT=3001

# Environment mode
NODE_ENV=development
