# ============================================
# AI Healthcare Avatar Platform - Frontend
# React + Vite + Production Optimized
# ============================================

# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies (clean install for production)
RUN npm ci --only=production && npm cache clean --force

# Copy source code
COPY frontend/ .

# Build the application
ARG VITE_API_URL=http://localhost:3001
ARG VITE_PROD_API_URL=http://localhost:3001
ARG VITE_ENABLE_SPEECH=true
ARG VITE_ENABLE_STREAMING=true
ARG VITE_ENABLE_EMOTIONS=true

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_PROD_API_URL=${VITE_PROD_API_URL}
ENV VITE_ENABLE_SPEECH=${VITE_ENABLE_SPEECH}
ENV VITE_ENABLE_STREAMING=${VITE_ENABLE_STREAMING}
ENV VITE_ENABLE_EMOTIONS=${VITE_ENABLE_EMOTIONS}

RUN npm run build

# Production stage - nginx
FROM nginx:alpine

# Install security updates
RUN apk upgrade --no-cache

# Copy custom nginx config
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from builder stage
COPY --from=builder /app/dist /usr/share/nginx/html

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:80/ || exit 1

# Expose port
EXPOSE 80

# Run nginx in foreground
CMD ["nginx", "-g", "daemon off;"]
